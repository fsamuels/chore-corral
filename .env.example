# Supabase — client-exposed public values (see docs/ARCHITECTURE.md).
# Copy to .env and fill in from the Supabase dashboard: Project Settings → API.
NUXT_PUBLIC_SUPABASE_URL=
NUXT_PUBLIC_SUPABASE_KEY=

# Mapbox — public access token for satellite map tiles (see docs/ARCHITECTURE.md).
# Optional: without it the map view falls back to OSM street tiles only.
NUXT_PUBLIC_MAPBOX_TOKEN=

# Database password (not used by the app — for direct DB access / supabase CLI).
# SUPABASE_DB_PASSWORD=

# Google OAuth client (Supabase auth.external.google) — from Google Cloud Console
# Credentials, used by `supabase config push` to configure the hosted project's
# Google provider. Not read by the Nuxt app itself.
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

# Playwright e2e tests only (tests/e2e/global-setup.ts) — never used by the
# app itself. The service role key bypasses RLS to seed a test user/farm; it
# must never be exposed to the client or committed. From the Supabase
# dashboard: Project Settings → API → service_role secret.
# SUPABASE_SERVICE_ROLE_KEY=
# E2E_TEST_USER_EMAIL=
# E2E_TEST_USER_PASSWORD=
# E2E_TEST_FARM_NAME=
